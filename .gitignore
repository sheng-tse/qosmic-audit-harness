node_modules/
*.zip
.DS_Store
**/.DS_Store
takehome/
__MACOSX

# Crawl raw text and data files are heavy and regenerated by scripts/crawl.mjs, so
# keep them out of git. The manifest and screenshots ARE committed: a clone needs
# the manifest for grade.mjs to reproduce grounding, and the report's evidence
# citations point at the screenshots.
sample_output/**/crawl/data/
sample_output/**/crawl/pages/

# grade.mjs writes eval.json next to whatever report it grades. The committed
# fixtures are the report and manifest; the scored output is a byproduct.
eval/cases/**/eval.json

# This repo's .claude/ IS the deliverable, so override the global ignore of it.
# Keep Claude Code's local-only state out, though.
!.claude/
!.claude/**
.claude/settings.local.json
